{
  "manifest_version": 3,
  "name": "My Simple Extension",
  "version": "1.0",
  "description": "Akrivia Logout Time Extension",
  "permissions": ["scripting", "storage"],
  "host_permissions": [
    "https://caliber.akriviahcm.com/time-attendance/UserAttendance*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://caliber.akriviahcm.com/time-attendance/UserAttendance*"],
      "js": [".content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}

